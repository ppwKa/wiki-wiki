{%- comment -%}
  通用：分类 → 产品 两级筛选（PC 端触发器 + 双列下拉）

  传参（命名约定）：
  - catalog_root     — 必填。站点内目录树根页面对象；`.children` 为分类，分类的 `.children` 为产品页
  - controller_name  — 必填。与页面 `data-controller` 中的筛选控制器一致，如 `catalog-index`（用于 `data-action`）
  - placeholder_label — 可选。未选产品时触发器与标签占位文案，默认 "Choose Product Model"
  - include_all_regions_first — 可选。为 true 时在第一列地区前增加「All」，右侧展示全部国家（data-cat-path="__all__"）
  - clickable_all_options — 可选。为 true 时「All」为直接可点击选项（非 hover 展开）；各地区的子级首项也为可点击「All」
  - global_all_label — 可选。第一列「全部」选项文案，默认 "All"
  - region_all_label — 可选。各地区子级首项「全部」文案，默认 "All"
  - hide_filter_thumbnail — 可选。为 true 时隐藏触发器左侧缩略图/占位图

  配套：`src/stylesheets/catalog.css`（根节点 `.catalog-index-page` 或与 FAQ 共用 `:is(.catalog-index-page,.faq-index-page)`）
        + `catalog_index_controller.js`；FAQ 聚合页另叠 `max-height-accordion`（见 `page.faq.liquid`）

  约定：产品链接使用 `data-turbo-frame="main-content-frame"` + `data-turbo-action="advance"`。
{%- endcomment -%}

{%- if placeholder_label == blank -%}
  {%- assign _placeholder = 'Choose Product Model' -%}
{%- else -%}
  {%- assign _placeholder = placeholder_label -%}
{%- endif -%}

{%- if global_all_label == blank -%}
  {%- assign _global_all_label = 'All' -%}
{%- else -%}
  {%- assign _global_all_label = global_all_label -%}
{%- endif -%}

{%- if region_all_label == blank -%}
  {%- assign _region_all_label = 'All' -%}
{%- else -%}
  {%- assign _region_all_label = region_all_label -%}
{%- endif -%}

<div class="filter-section">
  <p class="filter-label">{{ _placeholder }}</p>
  <div class="filter-container" id="filterContainer">
    <div class="filter-trigger-btn" id="filterHeader">
      <div class="filter-trigger-content">
        {%- unless hide_filter_thumbnail -%}
          <div class="filter-trigger-icon" id="thumbBox">
            <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100" fill="none">
              <rect width="100" height="100" fill="#F5F5F7"/>
              <rect x="10" y="10" width="80" height="80" fill="white"/>
            </svg>
          </div>
        {%- endunless -%}
        <span class="filter-trigger-text" id="selectedName">{{ _placeholder }}</span>
      </div>
      <svg
        class="filter-trigger-arrow"
        id="arrowIcon"
        xmlns="http://www.w3.org/2000/svg"
        width="36"
        height="36"
        viewBox="0 0 36 36"
        fill="none"
      >
        <path d="M24.5455 14.7275L18 21.273L11.4546 14.7275" stroke="#343436" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    {%- comment -%} PC 端两列下拉 {%- endcomment -%}
    <div class="pc-dropdown-menu hidden" id="pcDropdown">
      <div class="pc-category-list" id="pcCategoryList">
        {%- if include_all_regions_first -%}
          <div
            class="pc-category-item{% if clickable_all_options %} pc-category-item--direct-select{% endif %}"
            data-cat-path="__all__"
            data-name="{{ _global_all_label | escape }}"
            {% if clickable_all_options -%}
              data-action="click->{{ controller_name }}#selectGlobalAll"
            {%- endif -%}
          >
            {{ _global_all_label }}
            {%- unless clickable_all_options -%}
              <span class="pc-category-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                  <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {%- endunless -%}
          </div>
        {%- endif -%}
        {%- for cat in catalog_root.children -%}
          <div class="pc-category-item" data-cat-path="{{ cat.path }}">
            {{ cat.settings.title }}
            <span class="pc-category-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        {%- endfor -%}
      </div>

      <div class="pc-product-list" id="pcProductList">
        {%- for cat in catalog_root.children -%}
          {%- if clickable_all_options -%}
            <button
              type="button"
              class="pc-product-item pc-product-item--all"
              data-cat-path="{{ cat.path }}"
              data-path="__region_all__"
              data-name="{{ _region_all_label | escape }}"
              data-action="click->{{ controller_name }}#selectRegionAll"
            >
              {{ _region_all_label }}
            </button>
          {%- endif -%}
          {%- for prod in cat.children -%}
            <a
              href="{{ prod.path }}"
              class="pc-product-item"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
              data-cat-path="{{ cat.path }}"
              data-name="{{ prod.settings.title }}"
              data-thumb="{{ prod.settings.thumbnail | default: '' }}"
              data-path="{{ prod.path }}"
              data-action="click->{{ controller_name }}#closeDropdowns click->{{ controller_name }}#showSkeletonBeforeNavigate{% if clickable_all_options %} click->{{ controller_name }}#filterCardsBeforeNavigate{% endif %}"
            >
              {{ prod.settings.title }}
            </a>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>
