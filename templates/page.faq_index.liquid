<div class="faq-index-page" data-controller="faq-index">
  <div class="page-wrapper">
    <!-- 面包屑导航 -->
    <nav class="breadcrumb-nav">
      <a href="/" class="breadcrumb-link" data-turbo-frame="_top">{{ site.name }}</a>
      <span class="breadcrumb-separator">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
      <span class="breadcrumb-current">{{ page.settings.title }}</span>
    </nav>

    <!-- 主内容卡片 -->
    <div class="main-card">
      <h1 class="page-title">{{ page.settings.title }}</h1>

      <!-- 产品筛选器 -->
      <div class="filter-section">
        <p class="filter-label">Choose Product Model</p>
        <div class="filter-container" id="filterContainer">
          <div class="filter-trigger-btn" id="filterHeader">
            <div class="filter-trigger-content">
              <!-- 缩略图容器 (JS 将在有图片时替换 svg) -->
              <div class="filter-trigger-icon" id="thumbBox">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z">
                  </path>
                </svg>
              </div>

              <!-- 选中的产品名称 (由 JS 设置) -->
              <span class="filter-trigger-text" id="selectedName">Choose Product Model</span>
            </div>

            <svg
              class="filter-trigger-arrow"
              id="arrowIcon"
              xmlns="http://www.w3.org/2000/svg"
              width="36"
              height="36"
              viewBox="0 0 36 36"
              fill="none"
            >
              <path d="M24.5455 14.7275L18 21.273L11.4546 14.7275" stroke="#343436" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>

          <!-- PC 端下拉菜单 -->
          <div class="pc-dropdown-menu hidden" id="pcDropdown">
            <div class="pc-category-list" id="pcCategoryList">
              {%- for cat in page.children -%}
                <div class="pc-category-item" data-cat="{{ cat.settings.title }}">
                  {{ cat.settings.title }}
                  <span class="pc-category-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                      <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </div>
              {%- endfor -%}
            </div>

            <div class="pc-product-list" id="pcProductList">
              {%- for cat in page.children -%}
                {%- for prod in cat.children -%}
                  <div
                    class="pc-product-item"
                    data-cat="{{ cat.settings.title }}"
                    data-product="{{ prod.settings.title }}"
                    data-name="{{ prod.settings.title }}"
                    data-thumb="{{ prod.settings.thumbnail | default: '' }}"
                  >
                    {{ prod.settings.title }}
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ 内容区：懒加载，点击产品时加载 -->
      <div class="faq-content-wrapper" id="faqContentWrapper" data-faq-path="{{ page.path }}">
        <turbo-frame id="faq-content-frame" data-turbo-action="advance">
          <!-- 未选择产品时显示提示；加载时显示骨架屏 -->
          <div class="faq-content-placeholder" id="faqContentPlaceholder">
            <div class="faq-skeleton" id="faqSkeleton" style="display: none;">
              <div class="faq-skeleton-section">
                <div class="faq-skeleton-title"></div>
                <div class="faq-skeleton-item"></div>
                <div class="faq-skeleton-item"></div>
                <div class="faq-skeleton-item"></div>
              </div>
              <div class="faq-skeleton-section">
                <div class="faq-skeleton-title"></div>
                <div class="faq-skeleton-item"></div>
                <div class="faq-skeleton-item"></div>
              </div>
            </div>
            <p class="faq-select-hint" id="faqSelectHint">Choose a product model to view Quick Answer and Visual Guides.</p>
          </div>
        </turbo-frame>
      </div>
    </div>
  </div>

  <!-- 移动端底部弹窗 (修正版) -->
  <div class="mobile-overlay" id="mobileOverlay"></div>
  <div class="mobile-sheet" id="mobileSheet">
    <div class="mobile-sheet-header">
      <span class="mobile-sheet-title">Choose Product Model</span>
      <button class="mobile-sheet-close-btn" id="closeSheet">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M7.00049 7L15.0005 15" stroke="#343436" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M7.00049 15L15.0005 7" stroke="#343436" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>

    <div class="mobile-sheet-content" id="mobileAccordion">
      {%- for cat in page.children -%}
        <div class="mobile-accordion-item" data-cat="{{ cat.settings.title }}">
          <div class="mobile-accordion-header">
            <span class="mobile-accordion-title">{{ cat.settings.title }}</span>
            <svg
              class="mobile-accordion-arrow"
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 22 22"
              fill="none"
            >
              <path d="M15 9L11 13L7 9" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>

          <div class="mobile-accordion-content">
            <div class="mobile-accordion-list">
              {%- for prod in cat.children -%}
                <div
                  class="mobile-accordion-product"
                  data-cat="{{ cat.settings.title }}"
                  data-product="{{ prod.settings.title }}"
                  data-name="{{ prod.settings.title }}"
                  data-thumb="{{ prod.settings.thumbnail | default: '' }}"
                >
                  {{ prod.settings.title }}
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ Index",
  "description": "FAQ 聚合页模板",
  "sub_page_templates": ["faq_category"],
  "settings": [
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": "t:schema.templates.page.settings.description.label"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
