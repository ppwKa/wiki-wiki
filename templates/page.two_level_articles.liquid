{%- comment -%}
  双层文章模板：栏目根 → 直接子文章（无分类中间层）。依赖全局 `page`。

  页面树约定：
  /{root}              → 文章列表页（面包屑 + 标题 + guides 风格列表）
  /{root}/{article}    → 文章详情页（侧栏 TOC + 正文）

  渲染规则：
  depth 1 → 列表页
  depth 2 → 文章详情页（article-toc + tree_article_toc_*，toc_levels: 1）
  depth > 2 → 不渲染

  约束：页面树不要超过 2 层；子页请统一使用本模板 two_level_articles。
{%- endcomment -%}

{%- assign _depth = page.path | remove_first: '/' | split: '/' | size -%}

{%- assign tree_root = page -%}
{%- if _depth > 1 -%}{%- assign tree_root = page.parent -%}{%- endif -%}

<turbo-frame
  id="main-content-frame"
  class="block w-full"
  x-init="$el.addEventListener('turbo:before-fetch-request', () => { window.scrollTo({ top: 0, behavior: 'auto' }) })"
>
  {%- if _depth == 1 -%}
    <div class="article-toc-page two-level-articles-page two-level-articles-index">
      <div class="page-wrapper">
        <nav class="breadcrumb-nav">
          <a href="/" class="breadcrumb-link" data-turbo-frame="_top">{{ site.name }}</a>
          <span class="breadcrumb-separator">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="breadcrumb-current">{{ page.settings.title }}</span>
        </nav>

        <div class="page-main">
          <div class="page-main-container">
            <h1 class="page-title">{{ page.settings.title }}</h1>

            <div class="guides-section">
              <div class="guides-list">
                {%- assign article_index = 0 -%}
                {%- for child in page.children -%}
                  {%- assign article_index = article_index | plus: 1 -%}
                  <a
                    href="{{ child.path }}"
                    class="guide-card"
                    data-turbo-frame="main-content-frame"
                    data-turbo-action="advance"
                  >
                    <div class="guide-title">
                      <span>{{ article_index }}.</span>
                      <span>{{ child.settings.title }}</span>
                    </div>
                    <svg
                      class="guide-arrow"
                      xmlns="http://www.w3.org/2000/svg"
                      width="36"
                      height="36"
                      viewBox="0 0 36 36"
                      fill="none"
                    >
                      <path d="M16 12.5L22 18L16 23.5" stroke="#343436" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  {%- elsif _depth == 2 -%}
    <div class="article-toc-page two-level-articles-page" data-controller="article-toc">
      <div class="page-wrapper">
        <nav class="breadcrumb-nav">
          <a href="/" class="breadcrumb-link" data-turbo-frame="_top">{{ site.name }}</a>
          <span class="breadcrumb-separator">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>

          {%- if tree_root -%}
            <a
              href="{{ tree_root.path }}"
              class="breadcrumb-link"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >
              {{ tree_root.settings.title }}
            </a>
            <span class="breadcrumb-separator">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          {%- endif -%}

          <span class="breadcrumb-current">{{ page.settings.title }}</span>
        </nav>

        <div class="page-main">
          <div class="page-main-container">
            <div class="page-main-wrapper">
              <button
                class="contents-trigger-btn"
                id="contentsTrigger"
                aria-label="Open contents"
                type="button"
                data-action="click->article-toc#toggleSheet"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M7 9C7.55228 9 8 8.5523 8 8C8 7.44771 7.55228 7 7 7C6.44771 7 6 7.44771 6 8C6 8.5523 6.44771 9 7 9Z"
                    fill="#0071E3" />
                  <path
                    d="M7 13C7.55228 13 8 12.5523 8 12C8 11.4477 7.55228 11 7 11C6.44771 11 6 11.4477 6 12C6 12.5523 6.44771 13 7 13Z"
                    fill="#0071E3" />
                  <path
                    d="M7 17C7.55228 17 8 16.5523 8 16C8 15.4477 7.55228 15 7 15C6.44771 15 6 15.4477 6 16C6 16.5523 6.44771 17 7 17Z"
                    fill="#0071E3" />
                  <path d="M11 12H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M11 16H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M11 8H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                </svg>
                <span>Contents</span>
              </button>

              {%- render 'tree_article_toc_aside', tree_root: tree_root, toc_levels: 1 -%}

              <div class="page-main-content">
                <h1 class="page-main-title">{{ page.settings.title }}</h1>
                <article class="page-main-article">{{ page.settings.content }}</article>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- render 'tree_article_toc_sheet', tree_root: tree_root, title: tree_root.settings.title, toc_levels: 1 -%}
    </div>
  {%- endif -%}
</turbo-frame>
{% schema %}
{
  "name": "Two-level articles",
  "description": "双层文章模板：栏目根（文章列表）→ 子文章（详情+侧栏）",
  "sub_page_templates": ["two_level_articles", "page"],
  "settings": [
    {
      "id": "thumbnail",
      "type": "image_picker",
      "ratio": "1:1",
      "width": 100,
      "label": "t:schema.templates.page.settings.icon.label",
      "info": "t:schema.templates.page.settings.icon.info"
    },
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": "t:schema.templates.page.settings.description.label"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
