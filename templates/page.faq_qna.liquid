{%- assign product_page = page.parent -%}
{%- assign cat_page = product_page.parent -%}
{%- assign faq_path = cat_page.parent.path | default: '/faq' -%}

{%- assign cat = cat_page.slug -%}
{%- assign product = product_page.slug -%}
{%- assign q = page.slug -%}

<script>
  (function () {
    var target = "{{ faq_path }}?cat={{ cat | url_encode }}&product={{ product | url_encode }}&q={{ q | url_encode }}";
    window.location.replace(target);
  })();
</script>

<noscript>
  <p>Please <a href="{{ faq_path }}?cat={{ cat | url_encode }}&product={{ product | url_encode }}&q={{ q | url_encode }}">click here</a> to continue.</p>
</noscript>

{% schema %}
  {
    "name": "FAQ Detail",
    "description": "FAQ detail page",
    "thumb_url": "images/schema/page.png",
    "settings": [
      {
        "id": "title",
        "type": "text",
        "readonly": true,
        "label": "t:schema.templates.page.settings.title.label",
        "info": "t:schema.templates.page.settings.title.info"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.description.label"
      },
      {
        "id": "content",
        "type": "richtext",
        "label": "t:schema.templates.page.settings.content.label",
        "readonly": true,
        "info": "t:schema.templates.page.settings.content.info"
      }
    ]
  }
  {% endschema %}