{%- assign cat = page.link_text | handleize | url_encode -%}
{%- assign faq_path = page.parent.path | default: '/faq' -%}
<script>
  (function () {
    var target = "{{ faq_path }}?cat={{ cat }}";
    window.location.replace(target);
  })();
</script>

<noscript>
  <p>Please <a href="{{ faq_path }}?cat={{ cat }}">click here</a> to continue.</p>
</noscript>

{% schema %}
{
  "name": "FAQ Category",
  "description": "FAQ category container, redirects to FAQ index with category filter",
  "sub_page_templates": ["faq_product"]
}
{% endschema %}