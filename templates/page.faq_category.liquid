{%- assign faq_path = page.parent.path | default: '/faq' -%}
<script>
  (function () {
    function handleize(str) {
      if (!str || typeof str !== 'string') return '';
      return str
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
    }
    var title = '{{ page.settings.title }}';
    var cat = handleize(title);
    var target = cat ? '{{ faq_path }}?cat=' + encodeURIComponent(cat) : '{{ faq_path }}';
    window.location.replace(target);
  })();
</script>

<noscript>
  <p>Please <a href="{{ faq_path }}" data-turbo-frame="_top">{{ page.settings.title }}</a> to continue.</p>
</noscript>

{% schema %}
{
  "name": "FAQ 分类",
  "description": "FAQ 分类页模板",
  "sub_page_templates": ["faq_product"],
  "settings": [
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": "t:schema.templates.page.settings.description.label"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
