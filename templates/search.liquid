{% assign search_placeholder = "templates.search.placeholder" | t: "搜索内容" | presence %}
{% unless search_placeholder %}{% assign search_placeholder = "search.placeholder" | t: "Search..." %}{% endunless %}

{% assign empty_message = "templates.search.no_results" | t: '没有搜索到内容' %}

<div class="psc-search-page" data-controller="psc-home psc-search">
  <div class="psc-container">
    <div class="search-bar">
      {% form_tag 'search', class: 'search-wrapper', data-turbo-frame: 'frame--search-results', data-turbo-action: 'advance' %}
        <div class="search-input-wrapper">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
            <path d="M12.4583 21.6667C17.5439 21.6667 21.6667 17.5439 21.6667 12.4583C21.6667 7.37273 17.5439 3.25 12.4583 3.25C7.37273 3.25 3.25 7.37273 3.25 12.4583C3.25 17.5439 7.37273 21.6667 12.4583 21.6667Z" stroke="#D2D2D7" stroke-linejoin="round"/>
            <path d="M19.0781 19.0781L23.6743 23.6743" stroke="#D2D2D7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input
            type="text"
            autofocus
            class="search-input"
            name="{{ form.keywords_field_name }}"
            value="{{ search.keywords | escape_once }}"
            placeholder="{{ search_placeholder }}"
            autocomplete="off"
            data-psc-home-target="searchInput"
            data-action="input->psc-home#searchInputChanged"
          >
          <button
            type="button"
            class="clear-btn"
            aria-label="Clear search"
            data-psc-home-target="clearBtn"
            data-action="click->psc-home#clearSearch"
            {% unless search.keywords %}hidden{% endunless %}
          >
            <svg class="clear-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 22C17.5229 22 22 17.5229 22 12C22 6.47715 17.5229 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5229 6.47715 22 12 22Z" fill="#6E6E73"/>
              <path d="M14.8282 9.17188L9.17139 14.8287" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M9.17188 9.17188L14.8287 14.8287" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <button type="submit" class="search-btn">{{ 'layout.theme.search_button' | t: 'Search' }}</button>
      {% endform_tag %}
    </div>

    <turbo-frame
      id="frame--search-results"
      class="search-results"
      data-action="turbo:before-fetch-request->psc-search#scrollToTop"
    >
      {% if search.tag %}
        <span class="psc-search-tag" style="background-color: {{ search.tag.color }}">{{ search.tag.name }}</span>
      {% endif %}

      {% if search.keywords or search.tag %}
        {% paginate_tag search.pages, as: 'items', per: 20 %}
          {% assign extends_size = search.extends | size %}
          {% assign items_size = items | size %}
          {% assign total_size = extends_size | plus: items_size %}
          {% assign results_total = paginate.total_count | default: paginate.total_entries | default: total_size %}

          {% if total_size > 0 %}
            <p class="results-count">{{ results_total }} {{ 'templates.search.results_count' | t: 'Results' }}</p>

            <div class="results-list">
              {% if search.page_number == 1 and extends_size > 0 %}
                {% for link in search.extends %}
                  <article class="result-item">
                    <h3 class="result-title">
                      <a href="{{ link.url }}" class="search-highlight-block" data-turbo-frame="_top">{{ link.link_text }}</a>
                    </h3>
                  </article>
                {% endfor %}
              {% endif %}

              {% for item in items %}
                <article class="result-item">
                  <h3 class="result-title">
                    <a href="{{ item.url }}" class="search-highlight-block" data-turbo-frame="_top">{{ item.highlighted_search_title }}</a>
                  </h3>
                  {% unless item.highlighted_search_content == empty %}
                    <p class="result-description search-highlight-block">{{ item.highlighted_search_content }}</p>
                  {% endunless %}
                </article>
              {% endfor %}
            </div>

            {% render 'psc_search_paginate', paginate: paginate %}
          {% else %}
            <p class="results-count">0 {{ 'templates.search.results_count' | t: 'Results' }}</p>
            <p class="psc-search-empty">{{ empty_message }}</p>
          {% endif %}
        {% endpaginate_tag %}
      {% else %}
        <p class="psc-search-empty">{{ empty_message }}</p>
      {% endif %}
    </turbo-frame>
  </div>
</div>
