{%- assign cat_page = page.parent -%}
{%- assign faq_path = cat_page.parent.path | default: '/faq' -%}
{%- assign cat = cat_page.settings.title | handleize | url_encode -%}

<script>
  (function () {
    var target = '{{ faq_path }}?cat={{ cat }}&product={{ page.settings.title | handleize | url_encode }}';
    window.location.replace(target);
  })();
</script>

<noscript>
  <p>
    Please
    <a href="{{ faq_path }}?cat={{ cat }}&product={{ page.settings.title | handleize | url_encode }}">
      {{- page.settings.title -}}
    </a>
    to continue.
  </p>
</noscript>

{% schema %}
{
  "name": "FAQ Product",
  "description": "FAQ product page",
  "sub_page_templates": ["faq_detail"],
  "settings": [
    {
      "id": "thumbnail",
      "type": "image_picker",
      "ratio": "1:1",
			"width": 100,
			"label": "t:schema.templates.page.settings.icon.label",
			"info": "t:schema.templates.page.settings.icon.info"
    },
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": "t:schema.templates.page.settings.description.label"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
