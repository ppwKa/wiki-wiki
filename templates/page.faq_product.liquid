{%- assign cat_page = page.parent -%}
{%- assign faq_path = cat_page.parent.path | default: '/faq' -%}

<script>
  (function () {
    function handleize(str) {
      if (!str || typeof str !== 'string') return '';
      return str
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
    }
    var catTitle = '{{ cat_page.settings.title | escape }}';
    var productTitle = '{{ page.settings.title | escape }}';
    var cat = handleize(catTitle);
    var product = handleize(productTitle);
    var target = (cat && product)
      ? '{{ faq_path }}?cat=' + encodeURIComponent(cat) + '&product=' + encodeURIComponent(product)
      : '{{ faq_path }}';
    window.location.replace(target);
  })();
</script>

<noscript>
  <p>
    Please
    <a href="{{ faq_path }}">{{ cat_page.settings.title }} - {{ page.settings.title }}</a>
    to continue.
  </p>
</noscript>

{% schema %}
{
  "name": "FAQ 产品",
  "description": "FAQ 产品页模板",
  "sub_page_templates": ["faq_detail"],
  "settings": [
    {
      "id": "thumbnail",
      "type": "image_picker",
      "ratio": "1:1",
			"width": 100,
			"label": "t:schema.templates.page.settings.icon.label",
			"info": "t:schema.templates.page.settings.icon.info"
    },
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": "t:schema.templates.page.settings.description.label"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
