{%- comment -%}
  FAQ 专用页面树模板

  页面树约定：
  /faq                           → FAQ Root
  /faq/{category}                → 分类页
  /faq/{category}/{product}      → 产品聚合页
  /faq/{category}/{product}/{article} → 文章详情页

  渲染规则：
  depth 1~3 → 聚合页（faq_index）
  depth 4   → 文章页（faq_detail）
  depth > 4 → 非法层级，不渲染

  内容角色约定：
  - Root：仅作为 FAQ 入口与分类容器
  - Category：仅作为产品分类容器
  - Product：用于承载 Quick Answer / Visual Guides 的聚合内容来源
  - Article：具体文章内容页

  维护约束：
  - 只允许使用上述 4 层结构
  - 不要跳层建页，例如 /faq/{category}/{article}
  - 不要超过 4 层
  - FAQ 树内页面统一使用 faq 模板
  - `is_hide_as_article` 仅对 article 层有效：
    true  → Quick Answer
    false → Visual Guide
{%- endcomment -%}

{%- assign _depth = page.path | remove_first: '/' | split: '/' | size -%}

{%- assign faq_root = page -%}
{%- if _depth > 1 -%}{%- assign faq_root = page.parent -%}{%- endif -%}
{%- if _depth > 2 -%}{%- assign faq_root = faq_root.parent -%}{%- endif -%}
{%- if _depth > 3 -%}{%- assign faq_root = faq_root.parent -%}{%- endif -%}

{%- assign init_cat = null -%}
{%- assign init_prod = null -%}

{%- if _depth == 1 -%}
  {%- for cat in page.children -%}
    {%- assign first_prod = cat.children | first -%}
    {%- if first_prod -%}
      {%- assign init_cat = cat -%}
      {%- assign init_prod = first_prod -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

{%- elsif _depth == 2 -%}
  {%- assign init_cat = page -%}
  {%- assign init_prod = page.children | first -%}

{%- elsif _depth == 3 -%}
  {%- assign init_cat = page.parent -%}
  {%- assign init_prod = page -%}
{%- endif -%}

{%- comment -%}
  ─────────────── TURBO
  FRAME 外壳 ───────────────
{%- endcomment -%}
<turbo-frame
  id="main-content-frame"
  class="block w-full"
  {% if _depth < 3 and init_prod %}src="{{ init_prod.path }}"{% endif %}
  x-init="$el.addEventListener('turbo:before-fetch-request', () => { window.scrollTo({ top: 0, behavior: 'auto' }) })"
>
  {%- if _depth < 4 -%}
    {%- comment -%} 聚合页（depth 1 / 2 / 3）— faq_index 结构 {%- endcomment -%}
    <div
      class="faq-index-page"
      data-controller="faq-index"
      data-faq-index-page-path-value="{{ page.path | escape }}"
      data-faq-index-init-cat-path-value="{% if init_cat %}{{ init_cat.path | escape }}{% endif %}"
      data-faq-index-init-product-path-value="{% if init_prod %}{{ init_prod.path | escape }}{% endif %}"
    >
      <div class="page-wrapper">
        {%- comment -%} 面包屑导航 {%- endcomment -%}
        <nav class="breadcrumb-nav">
          <a href="/" class="breadcrumb-link" data-turbo-frame="_top">{{ site.name }}</a>
          <span class="breadcrumb-separator">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="breadcrumb-current">{{ faq_root.settings.title }}</span>
        </nav>

        {%- comment -%} 主内容卡片 {%- endcomment -%}
        <div class="page-main">
          <h1 class="page-title">{{ faq_root.settings.title }}</h1>

          {%- render 'faq_product_filter', faq_root: faq_root -%}

          {%- render 'faq_content_area', init_prod: init_prod, init_cat: init_cat -%}
        </div>
      </div>

      {%- render 'faq_product_sheet', faq_root: faq_root, title: 'Choose Product Model' -%}
    </div>
  {%- elsif _depth == 4 -%}
    {%- comment -%} 文章页（depth 4）— faq_detail 结构 {%- endcomment -%}
    <div class="faq-detail-page" data-controller="faq-detail">
      <div class="page-wrapper">
        {%- comment -%} 面包屑：Site > FAQ Root > 文章标题 {%- endcomment -%}
        <nav class="breadcrumb-nav">
          <a href="/" class="breadcrumb-link" data-turbo-frame="_top">{{ site.name }}</a>
          <span class="breadcrumb-separator">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>

          {%- if faq_root -%}
            <a
              href="{{ faq_root.path }}"
              class="breadcrumb-link"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >
              {{ faq_root.settings.title }}
            </a>
            <span class="breadcrumb-separator">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          {%- endif -%}

          <span class="breadcrumb-current">{{ page.settings.title }}</span>
        </nav>

        <div class="page-main">
          <div class="page-main-container">
            <h1 class="page-title">Visual Guide</h1>
            <a href="{{ faq_root.path }}" class="back-to-faq-link" data-turbo-frame="main-content-frame" data-turbo-action="advance">
              <span>Back to FAQ</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M9 7L13 11L9 15" stroke="#007AFF" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>

            <div class="page-main-wrapper">
              <button
                class="contents-trigger-btn"
                id="contentsTrigger"
                aria-label="Open contents"
                type="button"
                data-action="click->faq-detail#toggleSheet"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M7 9C7.55228 9 8 8.5523 8 8C8 7.44771 7.55228 7 7 7C6.44771 7 6 7.44771 6 8C6 8.5523 6.44771 9 7 9Z"
                    fill="#0071E3" />
                  <path
                    d="M7 13C7.55228 13 8 12.5523 8 12C8 11.4477 7.55228 11 7 11C6.44771 11 6 11.4477 6 12C6 12.5523 6.44771 13 7 13Z"
                    fill="#0071E3" />
                  <path
                    d="M7 17C7.55228 17 8 16.5523 8 16C8 15.4477 7.55228 15 7 15C6.44771 15 6 15.4477 6 16C6 16.5523 6.44771 17 7 17Z"
                    fill="#0071E3" />
                  <path d="M11 12H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M11 16H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M11 8H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                </svg>
                <span>Contents</span>
              </button>

              {%- render 'faq_toc_aside', faq_root: faq_root -%}

              <div class="page-main-content">
                <h1 class="page-main-title">{{ page.settings.title }}</h1>
                <article class="page-main-article">{{ page.settings.content }}</article>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- render 'faq_toc_sheet', faq_root: faq_root, title: 'Visual Guide Contents' -%}
    </div>
    {%- comment -%} depth > 4 → 非法，不渲染任何内容 {%- endcomment -%}
  {%- endif -%}
</turbo-frame>
{% schema %}
{
  "name": "FAQ",
  "description": "FAQ 统一模板，深度 <4 为聚合页，深度=4 为文章页",
  "sub_page_templates": ["faq"],
  "settings": [
    {
      "id": "is_hide_as_article",
      "type": "checkbox",
      "label": "是否在Visual Guide列表中隐藏",
      "info": "勾选后在 FAQ 聚合页做为quick answer展示, 不勾选则作为visual guide展示",
      "default": false
    },
    {
      "id": "thumbnail",
      "type": "image_picker",
      "ratio": "1:1",
      "width": 100,
      "label": "t:schema.templates.page.settings.icon.label",
      "info": "t:schema.templates.page.settings.icon.info"
    },
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    { "id": "description", "type": "textarea", "label": "t:schema.templates.page.settings.description.label" },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
