<main class="container mx-auto py-8">
  <h1 class="text-2xl font-semibold">{{ page.settings.title }}</h1>

  <div class="prose max-w-none mt-6">
    {{ page.settings.content }}
  </div>
</main>

{% schema %}
  {
    "name": "FAQ Detail",
    "description": "FAQ detail page for Visual Guide or Quick Answer",
    "settings": [
      {
        "id": "is_quick_answer",
        "type": "checkbox",
        "label": "是否作为 Quick Answer",
        "info": "勾选后在 FAQ 首页以折叠形式展示；不勾选则作为 Visual Guide 显示为链接",
        "default": false
      },
      {
        "id": "title",
        "type": "text",
        "readonly": true,
        "label": "t:schema.templates.page.settings.title.label",
        "info": "t:schema.templates.page.settings.title.info"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.description.label"
      },
      {
        "id": "content",
        "type": "richtext",
        "label": "t:schema.templates.page.settings.content.label",
        "readonly": true,
        "info": "t:schema.templates.page.settings.content.info"
      }
    ]
  }
  {% endschema %}