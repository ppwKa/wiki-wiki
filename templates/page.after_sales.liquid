{%- comment -%}
  售后页面树（两层）：根 → 文章（无分类中间层）。
  任意层级 URL 均使用与 FAQ 文章页相同的版式；正文默认展示：
  - 根：第一篇子文章
  - 文章：当前页

  维护：不要跳层；不要超过 2 层；子页统一使用 after_sales 模板。
{%- endcomment -%}

{%- assign _depth = page.path | remove_first: '/' | split: '/' | size -%}

{%- assign after_sales_root = page -%}
{%- if _depth > 1 -%}{%- assign after_sales_root = page.parent -%}{%- endif -%}

{%- assign display_page = null -%}
{%- if _depth == 1 -%}
  {%- assign display_page = page.children | first -%}
{%- else -%}
  {%- assign display_page = page -%}
{%- endif -%}

<turbo-frame
  id="main-content-frame"
  class="block w-full"
  x-init="$el.addEventListener('turbo:before-fetch-request', () => { window.scrollTo({ top: 0, behavior: 'auto' }) })"
>
  {%- if _depth <= 2 -%}
    <div class="article-toc-page" data-controller="article-toc">
      <div class="page-wrapper">
        <nav class="breadcrumb-nav">
          <a href="/" class="breadcrumb-link" data-turbo-frame="_top">{{ site.name }}</a>
          <span class="breadcrumb-separator">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>

          {%- if after_sales_root -%}
            <a
              href="{{ after_sales_root.path }}"
              class="breadcrumb-link"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >
              {{ after_sales_root.settings.title }}
            </a>
          {%- endif -%}

          {%- if display_page and _depth == 2 -%}
            <span class="breadcrumb-separator">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M9 7L13 11L9 15" stroke="#6E6E73" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span class="breadcrumb-current">{{ display_page.settings.title }}</span>
          {%- endif -%}
        </nav>

        <div class="page-main">
          <div class="page-main-container">
            <h1 class="page-title">{{ after_sales_root.settings.title }}</h1>

            <div class="page-main-wrapper">
              <button
                class="contents-trigger-btn"
                id="contentsTrigger"
                aria-label="Open contents"
                type="button"
                data-action="click->article-toc#toggleSheet"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M7 9C7.55228 9 8 8.5523 8 8C8 7.44771 7.55228 7 7 7C6.44771 7 6 7.44771 6 8C6 8.5523 6.44771 9 7 9Z"
                    fill="#0071E3" />
                  <path
                    d="M7 13C7.55228 13 8 12.5523 8 12C8 11.4477 7.55228 11 7 11C6.44771 11 6 11.4477 6 12C6 12.5523 6.44771 13 7 13Z"
                    fill="#0071E3" />
                  <path
                    d="M7 17C7.55228 17 8 16.5523 8 16C8 15.4477 7.55228 15 7 15C6.44771 15 6 15.4477 6 16C6 16.5523 6.44771 17 7 17Z"
                    fill="#0071E3" />
                  <path d="M11 12H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M11 16H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M11 8H18" stroke="#0071E3" stroke-width="1.2" stroke-linecap="round"
                    stroke-linejoin="round" />
                </svg>
                <span>Contents</span>
              </button>

              {%- render 'tree_article_toc_aside', tree_root: after_sales_root, toc_levels: 1 -%}

              <div class="page-main-content">
                {%- if display_page -%}
                  <h1 class="page-main-title">{{ display_page.settings.title }}</h1>
                  <article class="page-main-article">{{ display_page.settings.content }}</article>
                {%- else -%}
                  <h1 class="page-main-title">{{ page.settings.title }}</h1>
                  <article class="page-main-article"></article>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- render 'tree_article_toc_sheet', tree_root: after_sales_root, title: after_sales_root.settings.title, toc_levels: 1 -%}
    </div>
  {%- endif -%}
</turbo-frame>
{% schema %}
{
  "name": "After sales",
  "description": "售后统一模板，深度 1~2: 根与文章，无分类层",
  "sub_page_templates": ["after_sales", "page"],
  "settings": [
    {
      "id": "thumbnail",
      "type": "image_picker",
      "ratio": "1:1",
      "width": 100,
      "label": "t:schema.templates.page.settings.icon.label",
      "info": "t:schema.templates.page.settings.icon.info"
    },
    {
      "id": "title",
      "type": "text",
      "readonly": true,
      "label": "t:schema.templates.page.settings.title.label",
      "info": "t:schema.templates.page.settings.title.info"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": "t:schema.templates.page.settings.description.label"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "t:schema.templates.page.settings.content.label",
      "readonly": true,
      "info": "t:schema.templates.page.settings.content.info"
    }
  ]
}
{% endschema %}
