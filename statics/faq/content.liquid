{% layout none %}
{% comment %}
  FAQ 产品内容懒加载接口
  参数: faq_path, cat, product (cat/product 为原始标题，非 handleize)
  返回: turbo-frame 包裹的 Quick Answer + Visual Guides
{% endcomment %}
{%- assign faq_path = params.faq_path | default: '/faq' -%}
{%- assign cat_title = params.cat -%}
{%- assign product_title = params.product -%}

<turbo-frame id="faq-content-frame">
  {%- assign faq_page = site.pages[faq_path] -%}
  {%- assign found_cat = null -%}
  {%- assign found_prod = null -%}
  {%- for cat in faq_page.children -%}
    {%- if cat.settings.title == cat_title -%}
      {%- assign found_cat = cat -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if found_cat -%}
    {%- for prod in found_cat.children -%}
      {%- if prod.settings.title == product_title -%}
        {%- assign found_prod = prod -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if found_prod -%}
    <!-- Quick Answer -->
    <div class="faq-section">
      <h2 class="section-title">Quick Answer</h2>
      <div class="faq-list" id="quickAnswerContainer">
        {%- assign qa_index = 0 -%}
        {%- for p in found_prod.children -%}
          {%- if p.settings.is_quick_answer -%}
            {%- assign qa_index = qa_index | plus: 1 -%}
            <div
              class="faq-item"
              data-type="qna"
              data-cat="{{ found_cat.settings.title }}"
              data-product="{{ found_prod.settings.title }}"
              data-q="{{ p.settings.title }}"
            >
              <button class="faq-trigger-btn">
                <div class="faq-question">
                  <span>{{ qa_index }}.</span>
                  <span>{{ p.settings.title }}</span>
                </div>
                <svg
                  class="faq-trigger-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="36"
                  height="36"
                  viewBox="0 0 36 36"
                  fill="none"
                >
                  <path d="M23.5 15L18 21L12.5 15" stroke="#343436" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
              <div class="faq-answer-container">
                <div class="faq-answer-content">
                  {{ p.settings.content }}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Visual Guides -->
    <div class="guides-section">
      <h2 class="section-title">Visual Guides</h2>
      <div class="guides-list" id="visualGuidesContainer">
        {%- assign guide_index = 0 -%}
        {%- for p in found_prod.children -%}
          {%- if p.settings.is_quick_answer == false -%}
            {%- assign guide_index = guide_index | plus: 1 -%}
            <a
              href="{{ p.url }}"
              class="guide-card"
              data-turbo-frame="_top"
              data-type="guide"
              data-cat="{{ found_cat.settings.title }}"
              data-product="{{ found_prod.settings.title }}"
            >
              <div class="guide-title">
                <span>{{ guide_index }}.</span>
                <span>{{ p.settings.title }}</span>
              </div>
              <svg
                class="guide-arrow"
                xmlns="http://www.w3.org/2000/svg"
                width="36"
                height="36"
                viewBox="0 0 36 36"
                fill="none"
              >
                <path d="M16 12.5L22 18L16 23.5" stroke="#343436" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- else -%}
    <div class="faq-empty-state">
      <p>No Quick Answer or Visual Guides for this product.</p>
    </div>
  {%- endif -%}
</turbo-frame>
